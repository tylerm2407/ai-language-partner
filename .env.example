# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# AI Backend (called via Supabase Edge Functions, not directly from client)
# AI_API_KEY is stored in Supabase Edge Function secrets, NOT here
EXPO_PUBLIC_AI_ENDPOINT=https://your-project-id.supabase.co/functions/v1/ai-chat

# Stripe
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-key-here

# Sentry (optional)
EXPO_PUBLIC_SENTRY_DSN=https://your-sentry-dsn-here

# App Config
EXPO_PUBLIC_APP_ENV=development
