# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Stripe payment links (from Stripe dashboard > Payment Links)
VITE_STRIPE_PRO_LINK=https://buy.stripe.com/your-pro-link
VITE_STRIPE_FAMILY_LINK=https://buy.stripe.com/your-family-link

# ANTHROPIC_API_KEY goes in Supabase Edge Function secrets, NOT here
# Set it with: supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
